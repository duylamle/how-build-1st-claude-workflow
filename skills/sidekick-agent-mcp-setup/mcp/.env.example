# sidekick-agent-mcp — example environment
# Copy to .env (or set via your MCP client's env block) and fill in real values.

# --- Required ---
SIDEKICK_API_KEY=sk-your-key-here
SIDEKICK_API_BASE=https://your-anthropic-compatible-endpoint/v1

# --- LLM tuning ---
SIDEKICK_MODEL=minimax/MiniMax-M2.7-highspeed
SIDEKICK_TEMPERATURE=0.2
SIDEKICK_MAX_TOKENS=8000
SIDEKICK_TOP_P=1.0
SIDEKICK_THINKING=1
SIDEKICK_TIMEOUT=60

# --- Workspace / safety ---
SIDEKICK_WORKSPACE_ROOT=/abs/path/to/your/workspace
# SIDEKICK_LOG_DIR=<workspace>/_logs/_sidekick-pending
SIDEKICK_EXTRA_BLACKLIST=secrets/**,_logs/**,_archive/**
SIDEKICK_FILE_SIZE_KB=500
SIDEKICK_TOTAL_KB=2000
SIDEKICK_MAX_FILES=10

# --- Agent loop (sidekick_agent_run) ---
# Empty = read-only. Glob patterns (comma-separated) to allow writes.
SIDEKICK_WRITE_ALLOWLIST=
SIDEKICK_AGENT_MAX_ITERATIONS=15
SIDEKICK_WRITE_FILE_SIZE_KB=200
SIDEKICK_READ_FILE_MAX_BYTES=100000

# --- Conversation store (narrow tools with conversation_id) ---
SIDEKICK_MAX_CONVERSATIONS=32
SIDEKICK_MAX_TURNS_PER_CONVERSATION=20
